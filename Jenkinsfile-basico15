pipeline {
    agent any
    options {
        skipDefaultCheckout()
    }
    parameters {
        string(name: 'REPOSITORIO', defaultValue: 'https://github.com/jacampano/pruebasWebApp.git', description: 'Repositorio que se quiere construir')
        string(name: 'RAMA', defaultValue: 'main', description: 'Rama que se quiere descargar')
    }
    stages {
        stage('Checkout explicito') {
            steps {
                echo "Obteniendo ${params.REPOSITORIO} en la rama ${params.RAMA}"
                checkout scmGit(
                    branches: [[name: params.RAMA]],
                    userRemoteConfigs: [[url: params.REPOSITORIO]]
                )
            }
        }

        stage('Inspeccionar repositorio') {
            steps {
                sh 'git rev-parse --short HEAD'
                sh 'ls -1'
            }
        }
    }
}
